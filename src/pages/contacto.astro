---
import { Image } from 'astro:assets';
import Layout1 from '../layouts/layout1.astro';
import Navbar from '../components/Navbar.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import montecontacto from '../assets/montecontacto.webp';
---

<Layout1 title="Contacto | Entre Hojas">
  <Navbar title="Entre Hojas" />

  <!-- Encabezado con Imagen de Fondo -->
  <div class="relative bg-gray-900 py-24 sm:py-32">
    <div class="absolute inset-0 overflow-hidden">
      <Image 
        src={montecontacto}
        alt="Paisaje de contacto de fondo" 
        class="h-full w-full object-cover object-center opacity-40"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/30 to-black/70"></div>
    </div>

    <div class="relative mx-auto max-w-7xl px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-6xl uppercase italic">
        Ponete en Contacto
      </h1>
      <p class="mt-4 text-lg leading-8 text-gray-300">
        Estamos para ayudarte. Envianos un mensaje o visitanos.
      </p>
    </div>
  </div>

  <main class="bg-gray-50 py-16 sm:py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 xl:gap-16">
      <!-- Columna Izquierda: Información de Contacto -->
      <div class="bg-white p-8 rounded-2xl border border-gray-100 shadow-sm">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Información</h2>
        
        <div class="space-y-6">
          <!-- Dirección -->
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center bg-green-100 text-green-800 rounded-lg">
              <i class="ph ph-map-pin-line text-2xl"></i>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-gray-800">Dirección</h3>
              <p class="text-gray-600">Av. Lavalle 2221</p>
              <p class="text-gray-500 text-sm">Posadas, Misiones, Argentina</p>
            </div>
          </div>

          <!-- Teléfono -->
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center bg-green-100 text-green-800 rounded-lg">
              <i class="ph ph-whatsapp-logo text-2xl"></i>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-gray-800">WhatsApp</h3>
              <a href="https://wa.me/5493764102637" target="_blank" class="text-gray-600 hover:text-[#2B5432] transition-colors">+54 9 3764 10-2637</a>
            </div>
          </div>

          <!-- Instagram -->
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center bg-green-100 text-green-800 rounded-lg">
              <i class="ph ph-instagram-logo text-2xl"></i>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-gray-800">Instagram</h3>
              <a href="https://www.instagram.com/entrehojasalojamiento" target="_blank" class="text-gray-600 hover:text-[#2B5432] transition-colors">Seguinos en @entrehojasalojamiento</a>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center bg-green-100 text-green-800 rounded-lg">
              <i class="ph ph-envelope-simple text-2xl"></i>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-gray-800">Email</h3>
              <a href="mailto:contacto@gambastore.com" class="text-gray-600 hover:text-orange-600 transition-colors">contacto@gambastore.com</a>
            </div>
          </div>

          <!-- Horarios -->
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center bg-green-100 text-green-800 rounded-lg">
              <i class="ph ph-clock text-2xl"></i>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-gray-800">Horarios de Atención</h3>
              <p class="text-gray-600">Lunes a Viernes: 9:00 - 18:00 hs</p>
              <p class="text-gray-600">Sábados: 9:00 - 13:00 hs</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Columna Derecha: Mapa -->
      <div class="aspect-w-16 aspect-h-9 lg:aspect-none lg:h-full rounded-2xl overflow-hidden border border-gray-100 shadow-sm">
        <!-- TODO: Reemplazar el `src` con la URL de Google Maps para la ubicación de "Entre Hojas" -->
        <iframe 
          src="https://www.google.com/maps/embed?pb=!4v1770837292067!6m8!1m7!1s6Vj3Sob4cWLtimIDX-H6rQ!2m2!1d-27.36937407864857!2d-55.90545065717156!3f93.0577956346095!4f-21.567310283819793!5f0.8557237672828326" 
          class="w-full h-full"
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación de Entre Hojas"
        ></iframe>
      </div>
      </div>
    </div>
  </main>

  <WhatsAppButton phone="5493764102637" message="Hola! Tengo una consulta desde la página de contacto." />
</Layout1>