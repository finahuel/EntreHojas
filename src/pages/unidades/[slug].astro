---
import { Image } from 'astro:assets';
import Layout1 from '../../layouts/layout1.astro';
import Navbar from '../../components/Navbar.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import { unidades, type Unidad } from '../../data/unidades';
import monteunidades from '../../assets/monteunidades.webp';

// 1. La función `getStaticPaths` le dice a Astro qué páginas generar.
// Se ejecutará una vez por cada unidad en nuestros datos.
export async function getStaticPaths() {
  return unidades.map(unidad => ({
    params: { slug: unidad.id }, // El `slug` en la URL coincidirá con el `id` de la unidad.
    props: { unidad }, // Pasamos todos los datos de la unidad a la página.
  }));
}

// 2. Obtenemos los datos de la unidad específica para esta página.
const { unidad } = Astro.props as { unidad: Unidad };

const { 
  nombre, 
  id,
  descripcionLarga, 
  imagenes, 
  capacidad, 
  amenidades, 
  precio 
} = unidad;

const APPS_SCRIPT_URL = import.meta.env.PUBLIC_APPS_SCRIPT_URL;
---

<Layout1 title={`${nombre} | Entre Hojas`}>
  <Navbar title="Entre Hojas" />

  <!-- Encabezado con Imagen de Fondo -->
  <div class="relative bg-gray-900 py-24 sm:py-32">
    <div class="absolute inset-0 overflow-hidden">
      <Image 
        src={monteunidades}
        alt={`Fondo de ${nombre}`} 
        class="h-full w-full object-cover object-center opacity-40"
      />
      <div class="absolute inset-0 bg-linear-to-b from-black/10 via-black/30 to-black/70"></div>
    </div>

    <div class="relative mx-auto max-w-7xl px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-6xl uppercase italic">
        {nombre}
      </h1>
      <p class="mt-4 text-lg leading-8 text-gray-300">
        Capacidad para {capacidad} personas
      </p>
    </div>
  </div>

  <main class="bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">

      <!-- Galería de Imágenes con diseño destacado -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8 md:mb-12">
        {imagenes.map((img, index) => (
          <button 
            class:list={[
            "overflow-hidden rounded-xl shadow-lg",
            "group focus:outline-none focus:ring-4 focus:ring-green-500/50 cursor-zoom-in",
            { 'col-span-2 row-span-2': index === 0 && imagenes.length > 1 } 
            ]}
            onclick={`openLightbox(${index})`}
            aria-label={`Ver imagen ${index + 1} ampliada`}
          >
            <Image 
              src={img} 
              alt={`Foto ${index + 1} de ${nombre}`}
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
            />
          </button>
        ))}
      </div>

      <!-- Contenido: Descripción y Amenidades -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold text-gray-800 mb-4 border-b pb-2">Sobre esta unidad</h2>
          <p class="text-gray-600 leading-relaxed whitespace-pre-line">{descripcionLarga}</p>
        </div>
        
        <div>
          <h2 class="text-2xl font-bold text-gray-800 mb-4 border-b pb-2">¿Qué ofrecemos?</h2>
          <ul class="space-y-3">
            {amenidades.map(amenidad => (
              <li class="flex items-center gap-3">
                <div class="w-6 h-6 shrink-0 flex items-center justify-center bg-green-100 rounded-full">
                  <i class="ph ph-check text-green-800 font-bold"></i> 
                </div>
                <span class="text-gray-700">{amenidad}</span>
              </li>
            ))}
          </ul>

          <!-- Sección de Precio -->
          <div class="mt-8 mb-4 border-t border-gray-100 pt-6">
            <p class="text-sm text-gray-500 font-medium mb-1">Valor por noche</p>
            <div class="flex items-baseline gap-2">
              <span class="text-base text-gray-500">Desde</span>
              <span id="precio-display" class="text-4xl font-bold text-[#2B5432]">${precio}</span>
              <span class="text-sm text-gray-400">/ noche</span>
            </div>
            <p class="text-xs text-gray-400 mt-2 italic">* El precio puede variar feriados o fines de semana.</p>
          </div>

          <a href={`https://wa.me/5493764102637?text=Hola!%20Quisiera%20reservar%20la%20unidad%20'${nombre}'`} target="_blank" rel="noopener noreferrer" class="mt-8 w-full text-center bg-[#2B5432] text-white font-bold py-3 px-6 rounded-full hover:bg-white hover:text-[#2B5432] border-2 border-transparent hover:border-[#2B5432] transition-all duration-300 inline-block">
            Reservar Ahora
          </a>
        </div>
      </div>

    </div>
  </main>

  <!-- Lightbox Modal (Galería Ampliada) -->
  <div id="lightbox" class="fixed inset-0 z-[100] bg-black/95 hidden opacity-0 transition-opacity duration-300 flex items-center justify-center backdrop-blur-sm" role="dialog" aria-modal="true">
    
    <!-- Botón Cerrar -->
    <button id="lightbox-close" class="absolute top-4 right-4 z-[110] text-white/70 hover:text-white p-2 rounded-full hover:bg-white/10 transition-colors">
      <i class="ph ph-x text-3xl"></i>
    </button>

    <!-- Botón Anterior -->
    <button id="lightbox-prev" class="absolute left-2 md:left-8 z-[110] text-white/70 hover:text-white p-2 rounded-full hover:bg-white/10 transition-colors hidden sm:block">
      <i class="ph ph-caret-left text-4xl"></i>
    </button>

    <!-- Botón Siguiente -->
    <button id="lightbox-next" class="absolute right-2 md:right-8 z-[110] text-white/70 hover:text-white p-2 rounded-full hover:bg-white/10 transition-colors hidden sm:block">
      <i class="ph ph-caret-right text-4xl"></i>
    </button>

    <!-- Contenedor Imagen -->
    <div class="relative w-full h-full flex items-center justify-center p-4">
      <img id="lightbox-img" src="" alt="Galería ampliada" class="max-h-[90vh] max-w-[95vw] object-contain shadow-2xl rounded-sm select-none" />
      
      <!-- Indicador de carga -->
      <div id="lightbox-loader" class="absolute inset-0 flex items-center justify-center">
        <div class="w-12 h-12 border-4 border-white/20 border-t-white rounded-full animate-spin"></div>
      </div>
    </div>

    <!-- Contador de imágenes -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 text-white/80 text-sm font-medium bg-black/50 px-3 py-1 rounded-full">
      <span id="lightbox-counter">1 / 1</span>
    </div>
  </div>

  <WhatsAppButton phone="5493764102637" message={`Hola!%20Tengo%20una%20consulta%20sobre%20la%20unidad%20'${nombre}'.`} />

  <script define:vars={{ imagenes: imagenes.map(img => img.src) }}>
    // Variables de estado
    let currentIndex = 0;
    const totalImages = imagenes.length;
    
    // Elementos del DOM
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    const closeBtn = document.getElementById('lightbox-close');
    const prevBtn = document.getElementById('lightbox-prev');
    const nextBtn = document.getElementById('lightbox-next');
    const counter = document.getElementById('lightbox-counter');
    const loader = document.getElementById('lightbox-loader');

    // Función global para abrir el lightbox (llamada desde el HTML)
    window.openLightbox = (index) => {
      currentIndex = index;
      updateLightboxImage();
      lightbox.classList.remove('hidden');
      // Pequeño timeout para permitir que el navegador renderice antes de la transición de opacidad
      requestAnimationFrame(() => {
        lightbox.classList.remove('opacity-0');
      });
      document.body.style.overflow = 'hidden'; // Evitar scroll de fondo
    };

    function closeLightbox() {
      lightbox.classList.add('opacity-0');
      setTimeout(() => {
        lightbox.classList.add('hidden');
        lightboxImg.src = ''; // Limpiar src
      }, 300);
      document.body.style.overflow = '';
    }

    function updateLightboxImage() {
      loader.classList.remove('hidden');
      lightboxImg.style.opacity = '0.5';
      
      const img = new Image();
      img.src = imagenes[currentIndex];
      
      img.onload = () => {
        lightboxImg.src = imagenes[currentIndex];
        lightboxImg.style.opacity = '1';
        loader.classList.add('hidden');
      };

      counter.textContent = `${currentIndex + 1} / ${totalImages}`;
    }

    function showNext() {
      currentIndex = (currentIndex + 1) % totalImages;
      updateLightboxImage();
    }

    function showPrev() {
      currentIndex = (currentIndex - 1 + totalImages) % totalImages;
      updateLightboxImage();
    }

    // Event Listeners
    closeBtn.addEventListener('click', closeLightbox);
    nextBtn.addEventListener('click', (e) => { e.stopPropagation(); showNext(); });
    prevBtn.addEventListener('click', (e) => { e.stopPropagation(); showPrev(); });
    
    // Cerrar al hacer click fuera de la imagen
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox || e.target.closest('.w-full')) { // Click en el overlay
        closeLightbox();
      }
    });

    // Navegación con teclado
    document.addEventListener('keydown', (e) => {
      if (lightbox.classList.contains('hidden')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowRight') showNext();
      if (e.key === 'ArrowLeft') showPrev();
    });

    // Lógica para deslizar (Swipe) en móviles
    let touchStartX = 0;
    let touchEndX = 0;

    lightbox.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    lightbox.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      handleSwipe();
    }, { passive: true });

    function handleSwipe() {
      const threshold = 50; // Mínima distancia para considerar swipe
      if (touchEndX < touchStartX - threshold) showNext(); // Deslizar izquierda -> Siguiente
      if (touchEndX > touchStartX + threshold) showPrev(); // Deslizar derecha -> Anterior
    }
  </script>

  <script define:vars={{ APPS_SCRIPT_URL, unitId: id }}>
    // Lógica para consultar precio actualizado desde Google Sheets
    document.addEventListener('DOMContentLoaded', async () => {
      if (!APPS_SCRIPT_URL) return;

      const precioDisplay = document.getElementById('precio-display');
      
      try {
        // Consultamos a la API enviando el ID de la unidad y la acción específica
        // Nota: Asegúrate de que tu Google Apps Script maneje el parámetro "action=get_price"
        const response = await fetch(`${APPS_SCRIPT_URL}?action=get_price&id=${unitId}`);
        
        if (response.ok) {
          const data = await response.json();
          // Si la API devuelve un precio válido, actualizamos el DOM
          if (data && data.price) {
            precioDisplay.textContent = `$${data.price}`;
            // Opcional: Agregar una animación visual para indicar que se actualizó
            precioDisplay.classList.add('animate-pulse');
            setTimeout(() => precioDisplay.classList.remove('animate-pulse'), 1000);
          }
        }
      } catch (error) {
        console.error("No se pudo actualizar el precio desde el Sheet:", error);
        // Fallback silencioso: se mantiene el precio estático original
      }
    });
  </script>
</Layout1>