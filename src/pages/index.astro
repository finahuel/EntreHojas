---
import Layout1 from '../layouts/layout1.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Testimonios from '../components/Testimonios.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import UnidadCard from '../components/UnidadCard.astro';
import { unidades } from '../data/unidades';

// Función para barajar un array (algoritmo de Fisher-Yates)
function shuffle(array: any[]) {
  for (let i = array.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [array[i], array[j]] = [array[j], array[i]];
  }
  return array;
}

// Seleccionamos 3 unidades al azar para mostrar en la página de inicio
const unidadesDestacadas = shuffle([...unidades]).slice(0, 3);
---

<Layout1 title="Entre Hojas | Inicio">
  <Navbar title="Entre Hojas" />
  
  <Hero unidades={unidades} />

  <Testimonios />

  <!-- Sección de Unidades -->
  <div id="ofertas" class="bg-gray-50 scroll-mt-16">
    <div class="max-w-7xl mx-auto py-16 px-4 sm:py-24 sm:px-6 lg:px-8 ">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold tracking-tight text-gray-900 sm:text-4xl">
          Nuestras Unidades Mas Elegidas
        </h2>
        <p class="mt-4 max-w-2xl mx-auto text-lg text-gray-500">
          Espacios diseñados para tu confort y conexión con la naturaleza.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-y-10 sm:grid-cols-2 lg:grid-cols-3 gap-x-6">
        {unidadesDestacadas.map(unidad => (
          <UnidadCard 
            id={unidad.id}
            nombre={unidad.nombre}
            descripcion={unidad.descripcion}
            imagen={unidad.imagenPrincipal}
            capacidad={unidad.capacidad}
            amenidades={unidad.amenidades}
            precio={unidad.precio}
          />
        ))}
      </div>

      <div class="mt-12 text-center">
        <a href={import.meta.env.BASE_URL + "unidades"} class="inline-flex items-center px-8 py-3 border border-transparent text-base font-medium rounded-full shadow-sm text-white bg-[#2B5432] hover:bg-[#234429] transition-all duration-300 hover:shadow-md hover:-translate-y-0.5">
          Ver todas las unidades
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>

  <WhatsAppButton />
</Layout1>