---
import Layout1 from '../layouts/layout1.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Testimonios from '../components/Testimonios.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

---

<Layout1 title="Entre Hojas | Inicio">
  <Navbar title="Entre Hojas" />
  
  <Hero />

  <Testimonios />

  <!-- Sección de Unidades -->
  <div id="ofertas" class="bg-gray-50 scroll-mt-16">
    <div class="max-w-7xl mx-auto py-16 px-4 sm:py-24 sm:px-6 lg:px-8 ">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold tracking-tight text-gray-900 sm:text-4xl">
          Nuestras Unidades
        </h2>
        <p class="mt-4 max-w-2xl mx-auto text-lg text-gray-500">
          Espacios diseñados para tu confort y conexión con la naturaleza.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-y-10 sm:grid-cols-2 lg:grid-cols-3 gap-x-6">
        <!-- Placeholder de Unidad 1 -->
        <div class="group relative bg-white rounded-2xl shadow-sm overflow-hidden hover:shadow-lg transition-all">
          <div class="aspect-w-1 aspect-h-1 w-full overflow-hidden bg-gray-200 h-64">
             <!-- Puedes poner una imagen real aquí luego -->
             <div class="w-full h-full bg-gray-300 flex items-center justify-center text-gray-500">Imagen Unidad</div>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-gray-900">Cabaña del Bosque</h3>
            <p class="mt-2 text-gray-500 text-sm">Ideal para parejas. Vista panorámica.</p>
            <p class="mt-4 text-orange-600 font-bold">Consultar disponibilidad</p>
          </div>
        </div>

        <!-- Placeholder de Unidad 2 -->
        <div class="group relative bg-white rounded-2xl shadow-sm overflow-hidden hover:shadow-lg transition-all">
          <div class="aspect-w-1 aspect-h-1 w-full overflow-hidden bg-gray-200 h-64">
             <div class="w-full h-full bg-gray-300 flex items-center justify-center text-gray-500">Imagen Unidad</div>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-gray-900">Suite Mirador</h3>
            <p class="mt-2 text-gray-500 text-sm">Espacio amplio con jacuzzi y terraza.</p>
            <p class="mt-4 text-orange-600 font-bold">Consultar disponibilidad</p>
          </div>
        </div>

         <!-- Placeholder de Unidad 3 -->
         <div class="group relative bg-white rounded-2xl shadow-sm overflow-hidden hover:shadow-lg transition-all">
          <div class="aspect-w-1 aspect-h-1 w-full overflow-hidden bg-gray-200 h-64">
             <div class="w-full h-full bg-gray-300 flex items-center justify-center text-gray-500">Imagen Unidad</div>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-gray-900">Domo Glamping</h3>
            <p class="mt-2 text-gray-500 text-sm">Experiencia inmersiva bajo las estrellas.</p>
            <p class="mt-4 text-orange-600 font-bold">Consultar disponibilidad</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <WhatsAppButton />
</Layout1>