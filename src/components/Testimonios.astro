// Duplicamos los testimonios para crear el efecto de bucle infinito sin cortes
const testimoniosInfinitos = [...testimonios, ...testimonios];
---

<section class="bg-white py-16 sm:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Cabecera estilo Google Maps -->
    <div class="flex flex-col items-center justify-center mb-12 text-center">
      <h2 class="text-2xl font-bold text-gray-800 mb-2">Opiniones de clientes</h2>
      <div class="flex items-center gap-4 bg-white p-4 rounded-xl shadow-sm border border-gray-100">
        <div class="flex flex-col items-center">
          <span class="text-5xl font-bold text-gray-900">4.8</span>
          <div class="flex text-yellow-400 text-lg mt-1">
            <i class="ph-fill ph-star"></i>
            <i class="ph-fill ph-star"></i>
            <i class="ph-fill ph-star"></i>
            <i class="ph-fill ph-star"></i>
            <i class="ph-fill ph-star-half"></i>
          </div>
          <span class="text-xs text-gray-500 mt-1">214 reseñas en Google</span>
        </div>
        <div class="h-12 w-px bg-gray-200 mx-2"></div>
        <div class="flex flex-col items-start gap-1">
            <div class="flex items-center gap-2">
                <span class="text-xs font-medium text-gray-600 w-3">5</span>
                <div class="w-24 h-2 bg-gray-200 rounded-full overflow-hidden">
                    <div class="bg-yellow-400 h-full w-[90%]"></div>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <span class="text-xs font-medium text-gray-600 w-3">4</span>
                <div class="w-24 h-2 bg-gray-200 rounded-full overflow-hidden">
                    <div class="bg-yellow-400 h-full w-[10%]"></div>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <span class="text-xs font-medium text-gray-600 w-3">3</span>
                <div class="w-24 h-2 bg-gray-200 rounded-full overflow-hidden">
                    <div class="bg-gray-300 h-full w-[0%]"></div>
                </div>
            </div>
        </div>
      </div>
    </div>

    <!-- Carrusel de Reseñas -->
    <div class="relative overflow-hidden">
      <div id="carousel-track" class="flex will-change-transform cursor-grab active:cursor-grabbing touch-pan-y">
      {testimoniosInfinitos.map((item) => (
        <div class="w-full md:w-1/2 lg:w-1/3 shrink-0 px-4">
          <div class="flex flex-col bg-white border border-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow h-full">
          <!-- Header de la tarjeta -->
          <div class="flex items-start gap-3 mb-3">
            <!-- Avatar con inicial -->
            <div class="w-10 h-10 rounded-full bg-orange-600 flex items-center justify-center text-white font-medium text-lg shrink-0">
              {item.nombre.charAt(0)}
            </div>
            <div class="flex flex-col">
              <span class="font-bold text-gray-900 text-sm">{item.nombre}</span>
              <span class="text-xs text-gray-500">{item.cantidadResenas} reseñas</span>
            </div>
            <a href={item.link} target="_blank" rel="noopener noreferrer" class="ml-auto" aria-label="Ver reseña en Google">
              <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" alt="Google" class="w-5 h-5 opacity-70 hover:opacity-100 transition-opacity" />
            </a>
          </div>

          <!-- Estrellas y fecha -->
          <div class="flex items-center gap-2 mb-3">
            <div class="flex text-yellow-400 text-sm">
              {[...Array(5)].map((_, i) => (
                <i class={`ph-fill ${i < (item.rating || 5) ? 'ph-star' : 'ph-star text-gray-300'}`}></i>
              ))}
            </div>
            <span class="text-xs text-gray-500">{item.fecha}</span>
          </div>

          <!-- Texto -->
          <p class="text-gray-700 text-sm leading-relaxed">
            {item.testimonio}
          </p>
          </div>
        </div>
      ))}
      </div>
    </div>

    <div class="text-center mt-12">
        <a href="https://maps.app.goo.gl/x5ZM59Hmzps8XoNs7" target="_blank" class="inline-flex items-center gap-2 px-6 py-2 border border-gray-300 rounded-full text-blue-600 font-medium hover:bg-blue-50 transition-colors text-sm">
            Ver todas las reseñas
            <i class="ph ph-arrow-square-out"></i>
        </a>
    </div>
  </div>
</section>

<script>
  const track = document.getElementById('carousel-track');
  
  if (track) {
    let scrollPosition = 0;
    const speed = 0.5; // Velocidad del movimiento (ajustar si se quiere más rápido)
    let isPaused = false;
    let isDragging = false;
    let startX = 0;
    let startScrollPos = 0;
    let halfWidth = track.scrollWidth / 2;

    function animate() {
      if (!isPaused && !isDragging) {
        scrollPosition += speed;
        
        // Si llegamos al final del primer set (mitad del total), reseteamos a 0
        // Esto crea la ilusión de infinito
        if (scrollPosition >= halfWidth) {
          scrollPosition = 0;
        }
        
        track.style.transform = `translateX(-${scrollPosition}px)`;
      }
      requestAnimationFrame(animate);
    }

    animate();

    window.addEventListener('resize', () => {
      halfWidth = track.scrollWidth / 2;
    });

    // Pausa al pasar el mouse, pero solo si no se está arrastrando
    track.addEventListener('mouseenter', () => { if (!isDragging) isPaused = true; });
    track.addEventListener('mouseleave', () => { if (!isDragging) isPaused = false; });

    // --- Lógica de Arrastre (Drag & Drop / Touch) ---
    const startDrag = (e) => {
      isDragging = true;
      isPaused = true;
      startX = e.pageX || e.touches[0].pageX;
      startScrollPos = scrollPosition;
      track.style.cursor = 'grabbing';
    };

    const moveDrag = (e) => {
      if (!isDragging) return;
      const currentX = e.pageX || e.touches[0].pageX;
      const diff = currentX - startX;
      scrollPosition = startScrollPos - diff;

      // Bucle infinito manual durante el arrastre
      if (scrollPosition < 0) scrollPosition += halfWidth;
      if (scrollPosition >= halfWidth) scrollPosition -= halfWidth;

      track.style.transform = `translateX(-${scrollPosition}px)`;
    };

    const endDrag = () => {
      isDragging = false;
      track.style.cursor = 'grab';
      // Si el mouse ya no está encima (o es touch), reanudamos
      if (!track.matches(':hover')) isPaused = false;
    };

    // Eventos Mouse
    track.addEventListener('mousedown', startDrag);
    window.addEventListener('mousemove', moveDrag);
    window.addEventListener('mouseup', endDrag);

    // Eventos Touch
    track.addEventListener('touchstart', startDrag, { passive: true });
    track.addEventListener('touchmove', moveDrag, { passive: true });
    track.addEventListener('touchend', () => {
      endDrag();
      isPaused = false; // En móvil siempre reanudamos al soltar
    });
  }
</script>