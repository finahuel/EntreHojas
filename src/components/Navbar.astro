---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';

interface Props {
  title?: string;
}

const { title = "Entre Hojas" } = Astro.props;
---

<nav class="fixed w-full z-50 transition-all duration-500 py-6" id="navbar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-12">
      <a href={import.meta.env.BASE_URL} class="flex items-center group cursor-pointer">
        <Image src={logo} alt={title} class="h-20 w-auto object-contain" loading="eager" />
      </a>

      <!-- Agrupamos Menú y Iconos a la derecha -->
      <div class="flex items-center gap-8">
        <div class="hidden md:flex items-center space-x-8">
          <a
            href={import.meta.env.BASE_URL}
            class="text-white/90 nav-text hover:text-[#2B5432] font-medium transition"
          >
            Inicio
          </a>
          <a
            href={import.meta.env.BASE_URL + "unidades"}
            class="text-white/90 nav-text hover:text-[#2B5432] font-medium transition"
          >
            Unidades
          </a> 
          <a
            href={import.meta.env.BASE_URL + "contacto"}
            class="text-white/90 nav-text hover:text-[#2B5432] font-medium transition"
          >
            Contacto
          </a>
        </div>

        <!-- Contenedor Iconos Derecha (Carrito + Menú Móvil) -->
        <div class="flex items-center gap-4">
          <!-- Instagram -->
          <a href="https://www.instagram.com/entrehojasalojamiento" target="_blank" class="text-white/90 hover:text-green-300 transition cursor-pointer" aria-label="Síguenos en Instagram">
            <i class="ph ph-instagram-logo text-2xl"></i>
          </a>

          <!-- Botón Menú Hamburguesa (Solo móvil) -->
          <div class="md:hidden">
            <button onclick="toggleMobileMenu()" class="text-white nav-text p-2 focus:outline-none transition-colors cursor-pointer">
              <i id="menuIconOpen" class="ph ph-list text-3xl block cursor-pointer"></i>
              <i id="menuIconClose" class="ph ph-x text-3xl hidden cursor-pointer"></i>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div
    id="mobileMenu"
    class="hidden md:hidden bg-white border-t p-4 space-y-3 shadow-2xl absolute w-full left-0 top-full"
  >
    <a
      href={import.meta.env.BASE_URL}
      onclick="closeMobileMenu()"
      class="block text-slate-600 hover:text-[#2B5432] font-medium py-3 border-b border-gray-100"
    >
      Inicio
    </a>
    <a
      href={import.meta.env.BASE_URL + "unidades"}
      onclick="closeMobileMenu()"
      class="block text-slate-600 hover:text-[#2B5432] font-medium py-3 border-b border-gray-100"
    >
      Unidades
    </a>
    <a
      href={import.meta.env.BASE_URL + "contacto"}
      onclick="closeMobileMenu()"
      class="block text-slate-600 hover:text-[#2B5432] font-medium py-3 border-b border-gray-100"
    >
      Contacto
    </a>
  </div>
</nav>

<script>
  function toggleMobileMenu() {
    const menu = document.getElementById("mobileMenu");
    const iconOpen = document.getElementById("menuIconOpen");
    const iconClose = document.getElementById("menuIconClose");
    if (!menu || !iconOpen || !iconClose) return;
    
    menu.classList.toggle("hidden");

    if (menu.classList.contains("hidden")) {
      iconOpen.classList.remove("hidden");
      iconClose.classList.add("hidden");
    } else {
      iconOpen.classList.add("hidden");
      iconClose.classList.remove("hidden");
      iconClose.style.color = "#0f172a";
    }
  }

  function closeMobileMenu() {
    const menu = document.getElementById("mobileMenu");
    const iconOpen = document.getElementById("menuIconOpen");
    const iconClose = document.getElementById("menuIconClose");
    if (!menu || !iconOpen || !iconClose) return;
    
    menu.classList.add("hidden");
    iconOpen.classList.remove("hidden");
    iconClose.classList.add("hidden");
  }

  // Lógica de navbar scroll
  const nav = document.getElementById("navbar");
  window.addEventListener("scroll", () => {
    if (!nav) return;
    if (window.scrollY > 50) {
      nav.classList.add("nav-scrolled");
    } else {
      nav.classList.remove("nav-scrolled");
    }
  });

  // Exponer funciones globalmente para botones
  window.toggleMobileMenu = toggleMobileMenu;
  window.closeMobileMenu = closeMobileMenu;
</script>

<style>
  /* Estilo para cuando se hace scroll */
  .nav-scrolled {
    background-color: rgba(36, 36, 37, 0.85); /* Fondo oscuro translúcido */
    backdrop-filter: blur(12px); /* Efecto de desenfoque (Glassmorphism) */
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    padding-top: 1rem !important; /* Reducimos un poco el padding para que sea más compacto */
    padding-bottom: 1rem !important;
  }
</style>
